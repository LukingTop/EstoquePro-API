# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÕES GERAIS DO DJANGO
# ──────────────────────────────────────────────────────────────────────────────
# Cole aqui uma chave de segurança para o ambiente local.
SECRET_KEY=sua-chave-secreta-django-aqui

# Defina como True para desenvolvimento local e False para produção
DEBUG=True

# Lista de hosts permitidos separados por vírgula (ex: 127.0.0.1,localhost,192.168.x.x)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÕES DO BANCO DE DADOS (POSTGRESQL)
# ──────────────────────────────────────────────────────────────────────────────
DB_NAME=nome_do_seu_banco
DB_USER=seu_usuario_do_banco
DB_PASSWORD=sua_senha_do_banco
DB_HOST=localhost
DB_PORT=5432

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÕES DO SENTRY (MONITORAMENTO DE ERROS)
# ──────────────────────────────────────────────────────────────────────────────
# Cole a URL do seu DSN do Sentry aqui
SENTRY_DSN=https://chave_publica@o_id_da_organizacao.ingest.sentry.io/id_do_projeto

# Ambiente do Sentry (development, staging, production)
SENTRY_ENVIRONMENT=development